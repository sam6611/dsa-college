#include <vector>
using namespace std;
class Solution {
  public:
    vector<int> nextSmallerEle(vector<int>& arr) {
        int n = arr.size();
        vector<int> result(n, -1);

        for (int i = 0; i < n; i++) {

            for (int j = i + 1; j < n; j++) {

                if (arr[j] < arr[i]) {
                    result[i] = arr[j];
                    break;  // stop at first smaller
                }
            }
        }

        return result;
    }
};