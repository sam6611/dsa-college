#include <queue>
#include <stack>
using namespace std;
class Solution {
  public:
    void reverseQueue(queue<int> &q) {
        stack<int> st;

        // Move elements to stack
        while (!q.empty()) {
            st.push(q.front());
            q.pop();
        }

        // Move back to queue
        while (!st.empty()) {
            q.push(st.top());
            st.pop();
        }
    }
};