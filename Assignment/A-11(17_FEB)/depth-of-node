#include <algorithm>
#include <cmath>
#include <vector>
#include <stack>
#include <string>
using namespace std;
struct Node
{
    int data;
    struct Node *left;
    struct Node *right;

    Node(int x)
    {
        data = x;
        left = NULL;
        right = NULL;
    }
};
class Solution {
  public:
  
    int solve(Node* root, int depth) {
        if (root == NULL)
            return 0;

        // Check if leaf node and odd value
        if (root->left == NULL && root->right == NULL && root->data % 2 != 0)
            return depth;

        // Check left and right subtree
        int left = solve(root->left, depth + 1);
        int right = solve(root->right, depth + 1);

        return max(left, right);
    }

    int depthOfOddLeaf(Node *root) {
        return solve(root, 1);
    }
};
